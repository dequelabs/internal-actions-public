{
  "name": "internal-actions-public",
  "version": "1.0.0",
  "description": "A collection of GitHub actions for internal use with public and private repositories",
  "scripts": {
    "prepare": "husky",
    "typecheck": "npm --workspaces run typecheck",
    "build": "npm --workspaces run build",
    "test": "npm --workspaces run test"
  },
  "license": "MPL-2.0",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "./.github/actions/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^24.0.0",
    "@types/sinon": "^17.0.3",
    "@vercel/ncc": "^0.38.2",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "sinon": "^19.0.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.16.0"
  },
  "lint-staged": {
    "*.{md,json,js,ts,html}": [
      "prettier --write"
    ],
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
