{
  "name": "a11y-sla-breach-labels",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to manage accessibility SLA breach labels on issues.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prebuild": "rimraf dist",
    "build": "ncc build src/index.ts --license ../../../licenses.txt",
    "test": "node --test \"src/**/*.test.ts\"",
    "coverage": "node --test --experimental-test-coverage --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-lines=100 \"src/**/*.test.ts\"",
    "fmt": "prettier --write \"src/**/*.{js,ts,tsx,json,md,css,html}\"",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\""
  },
  "license": "MPL-2.0",
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@types/node": "^22.7.9"
  }
}
